    "from sklearn.metrics import log_loss\n",
    "\n",
    "# True labels\n",
    "y_true = [0, 1, 1, 0]\n",
    "# Predicted probabilities\n",
    "y_pred = [0.1, 0.9, 0.8, 0.3]\n",
    "\n",
    "# Calculate Log Loss\n",
    "loss = log_loss(y_true, y_pred)\n",
    "print(\"Log Loss:\", loss)"
   ]
  }
